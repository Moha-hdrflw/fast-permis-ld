---
const CALENDLY = "https://calendly.com/fastpermis-rdv/30min?month=2026-04";

const formules = [
  {
    popular: true,
    name: "Boîte Automatique",
    price: "699€",
    subPrice: "Paiement en 3x = 233€/mois",
    features: [
      "13h de conduite",
      "dont 2h sur simulateur",
      "Dates d'examen rapides",
      "Paiement 3x ou 4x sans frais via Alma",
      "Accompagnement du début à la fin",
    ],
    cta: "Je réserve — Boîte Auto →",
  },
  {
    popular: false,
    name: "Boîte Manuelle",
    price: "990€",
    subPrice: "Paiement en 3x = 330€/mois",
    features: [
      "20h de conduite",
      "dont 3h sur simulateur",
      "Dates d'examen rapides",
      "Paiement 3x ou 4x sans frais via Alma",
      "Accompagnement du début à la fin",
    ],
    cta: "Je réserve — Boîte Manuelle →",
  },
];
---

<section id="formules">
  <div class="container">

    <div class="formules-header fade-up">
      <span class="section-label">Nos offres</span>
      <h2 class="section-title">Choisis ta <span>formule</span></h2>
    </div>

    <div class="cards-grid">
      {formules.map((f) => (
        <div class={`formula-card fade-up${f.popular ? ' popular' : ''}`}>
          <div class="formula-header">
            {f.popular && <span class="badge-popular">Le plus populaire</span>}
            {!f.popular && <div style="height:28px;" />}
            <div class="formula-name">{f.name}</div>
            <div class="formula-price">{f.price}</div>
            <div class="formula-sub-price" set:html={f.subPrice.replace('=', '= <strong>').replace('/mois', '/mois</strong>')} />
          </div>
          <div class="formula-body">
            <ul class="feature-list">
              {f.features.map((feat) => (
                <li><span class="check">✅</span> {feat}</li>
              ))}
            </ul>
            <a class="btn btn-full" href={CALENDLY} target="_blank" rel="noopener noreferrer">
              {f.cta}
            </a>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  #formules { background: var(--black); }

  .formules-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    max-width: 860px;
    margin: 0 auto;
  }

  .formula-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: border-color var(--transition), transform var(--transition), box-shadow var(--transition);
    position: relative;
  }
  .formula-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: var(--red);
    opacity: 0;
    transition: opacity var(--transition);
  }
  .formula-card:hover { border-color: var(--red); transform: translateY(-6px); box-shadow: 0 16px 48px rgba(232,19,10,0.12); }
  .formula-card:hover::before, .formula-card.popular::before { opacity: 1; }

  .formula-header {
    padding: 32px 28px 24px;
    border-bottom: 1px solid var(--border);
  }

  .badge-popular {
    display: inline-block;
    background: var(--red);
    color: var(--white);
    font-family: var(--font-title);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 100px;
    margin-bottom: 16px;
  }

  .formula-name {
    font-family: var(--font-title);
    font-weight: 800;
    font-size: 1.4rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    margin-bottom: 6px;
  }

  .formula-price {
    font-family: var(--font-title);
    font-weight: 900;
    font-size: 3.5rem;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--red);
  }

  .formula-sub-price {
    font-size: 0.88rem;
    color: var(--text-muted);
    margin-top: 6px;
  }

  .formula-body {
    padding: 28px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .feature-list {
    list-style: none;
    margin-bottom: 28px;
    flex: 1;
  }
  .feature-list li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 8px 0;
    font-size: 0.97rem;
    border-bottom: 1px solid var(--border);
  }
  .feature-list li:last-child { border-bottom: none; }
  .check { color: var(--red); font-size: 1rem; flex-shrink: 0; margin-top: 2px; }

  .btn-full { width: 100%; justify-content: center; }

  @media (max-width: 900px) {
    .cards-grid { grid-template-columns: 1fr; max-width: 480px; }
  }
</style>
