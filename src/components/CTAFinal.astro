---
const CALENDLY = "https://calendly.com/fastpermis-rdv/30min?month=2026-04";
---

<section id="cta-final">
  <div class="container fade-up">
    <h2 class="cta-title">Prêt à passer ton permis ?</h2>
    <p class="cta-sub">Réserve ton appel gratuit maintenant. Un conseiller te rappelle, répond à toutes tes questions et t'accompagne pas à pas.</p>
    <a class="btn btn-white btn-lg" href={CALENDLY} target="_blank" rel="noopener noreferrer">
      Je réserve mon appel gratuit →
    </a>
    <p class="cta-note">Disponible 7j/7 · Gratuit · Sans engagement</p>
  </div>
</section>

<style>
  #cta-final {
    background: var(--red);
    padding: 80px 20px;
    text-align: center;
  }

  .cta-title {
    font-family: var(--font-title);
    font-weight: 900;
    font-size: clamp(2.2rem, 6vw, 4rem);
    text-transform: uppercase;
    line-height: 1;
    letter-spacing: 0.01em;
    margin-bottom: 16px;
  }

  .cta-sub {
    font-size: clamp(1rem, 2vw, 1.15rem);
    color: rgba(255,255,255,0.85);
    max-width: 520px;
    margin: 0 auto 36px;
    line-height: 1.6;
  }

  .cta-note {
    margin-top: 16px;
    font-size: 0.85rem;
    color: rgba(255,255,255,0.7);
    letter-spacing: 0.07em;
    font-family: var(--font-title);
    text-transform: uppercase;
  }
</style>
