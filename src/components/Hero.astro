---
const CALENDLY = "https://calendly.com/fastpermis-rdv/30min?month=2026-04";
---

<section id="hero">
  <div class="hero-inner">

    <div class="hero-logo fade-up visible">
      <img src="/logo.png" alt="Fast Permis" />
    </div>

    <div class="hero-badge fade-up visible">
      <span class="pulse-dot"></span>
      Conseillers disponibles
    </div>

    <h1 class="hero-title fade-up visible">
      Ton Permis
      <span class="price">Dès 699€</span>
    </h1>

    <p class="hero-sub fade-up visible">
      Réserve un appel gratuit avec un conseiller. Il répond à toutes tes questions
      et t'accompagne pas à pas, sans pression.
    </p>

    <a class="btn btn-lg fade-up visible" href={CALENDLY} target="_blank" rel="noopener noreferrer">
      Je réserve mon appel gratuit →
    </a>

    <p class="hero-note fade-up visible">Gratuit · Sans engagement · 7j/7</p>

    <div class="hero-chips stagger fade-up visible">
      <span class="chip">🚀 Dates d'examen rapides</span>
      <span class="chip">💳 Paiement 3x ou 4x sans frais</span>
      <span class="chip">📞 Conseillers disponibles 7j/7</span>
    </div>

  </div>
</section>

<style>
  #hero {
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 120px 20px 80px;
    position: relative;
    overflow: hidden;
    text-align: center;
  }

  #hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 60% at 50% 50%, rgba(232,19,10,0.12) 0%, transparent 70%),
      radial-gradient(ellipse 40% 40% at 80% 20%, rgba(232,19,10,0.06) 0%, transparent 60%);
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 820px;
  }

  .hero-logo {
    margin-bottom: 24px;
  }
  .hero-logo img {
    height: 180px;
    width: auto;
    object-fit: contain;
    filter: drop-shadow(0 0 24px rgba(232,19,10,0.3));
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    background: rgba(34, 197, 94, 0.1);
    border: 1px solid rgba(34, 197, 94, 0.35);
    border-radius: 100px;
    padding: 7px 16px;
    font-family: var(--font-title);
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 28px;
    color: #4ade80;
  }

  .pulse-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: #22c55e;
    box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.6);
    animation: pulse-ring 2s ease-out infinite;
    flex-shrink: 0;
  }

  @keyframes pulse-ring {
    0%   { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.6); }
    60%  { box-shadow: 0 0 0 10px rgba(34, 197, 94, 0); }
    100% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0); }
  }

  .hero-title {
    font-family: var(--font-title);
    font-weight: 900;
    font-size: clamp(4.5rem, 14vw, 9rem);
    text-transform: uppercase;
    line-height: 0.92;
    letter-spacing: -0.01em;
    margin-bottom: 28px;
  }

  .hero-title .price {
    color: var(--red);
    text-shadow: 0 0 40px rgba(232,19,10,0.5), 0 0 80px rgba(232,19,10,0.2);
    display: block;
  }

  .hero-sub {
    font-size: clamp(1rem, 2.5vw, 1.2rem);
    color: rgba(255,255,255,0.78);
    max-width: 560px;
    margin: 0 auto 36px;
    line-height: 1.6;
  }

  .hero-note {
    margin-top: 16px;
    font-size: 0.85rem;
    color: var(--text-muted);
    letter-spacing: 0.06em;
    font-family: var(--font-title);
    text-transform: uppercase;
  }

  .hero-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
    margin-top: 48px;
  }

  .chip {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    background: rgba(255,255,255,0.05);
    border: 1px solid var(--border);
    border-radius: 100px;
    padding: 9px 18px;
    font-size: 0.9rem;
    font-weight: 500;
    transition: border-color var(--transition), background var(--transition);
  }
  .chip:hover {
    border-color: var(--border-red);
    background: rgba(232,19,10,0.06);
  }

  @media (max-width: 640px) {
    #hero { padding: 100px 16px 64px; }
    .hero-title { font-size: clamp(3.8rem, 18vw, 6rem); }
    .hero-chips { gap: 8px; }
    .chip { font-size: 0.82rem; padding: 8px 14px; }
  }
</style>
